generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model country {
  id   Int     @id @default(autoincrement())
  name String?
}

model state {
  id         Int     @id @default(autoincrement())
  name       String?
  code       String?
  country_id Int?
}

model district {
  id       Int     @id @default(autoincrement())
  name     String?
  code     String?
  state_id Int?
}

model subdistrict {
  id          Int     @id @default(autoincrement())
  name        String?
  code        String?
  district_id Int?
}

model village {
  id             Int     @id @default(autoincrement())
  name           String?
  code           String?
  subdistrict_id Int?
}